{
  "buildCommand": "npm ci --include=dev && npm run build",
  "outputDirectory": "dist/public",
  "installCommand": "npm ci --include=dev",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
